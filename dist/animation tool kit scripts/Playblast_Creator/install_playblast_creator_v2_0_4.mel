// Playblast Creator Tool v2.0.4 - Drag & Drop Installer
// Drag this MEL file into a Maya viewport or source it manually.

global proc string cstg_cleanWhatIsPath(string $whatIsValue)
{
    string $path = `substitute "Mel procedure found in: " $whatIsValue ""`;
    $path = `substitute "Script found in: " $path ""`;
    return $path;
}

global proc installPlayblastCreatorV204()
{
    string $whatIsValue = `whatIs installPlayblastCreatorV204`;
    string $resolvedPath = `cstg_cleanWhatIsPath $whatIsValue`;

    if (`gmatch $resolvedPath "Unknown*"`)
    {
        error "[Playblast Creator] Unable to resolve installer path. Save the file locally and retry.";
        return;
    }

    string $sourceDir = `dirname $resolvedPath`;
    $sourceDir = `substitute "\\\\" $sourceDir "/"`;

    string $pythonCmd = "import os, runpy\n";
    $pythonCmd += "source_dir = r'" + $sourceDir + "'\n";
    $pythonCmd += "installer = os.path.join(source_dir, 'install_playblast_creator_v2_0_4.py')\n";
    $pythonCmd += "if not os.path.exists(installer):\n";
    $pythonCmd += "    raise RuntimeError('[Playblast Creator] Missing installer file: {0}'.format(installer))\n";
    $pythonCmd += "installer_globals = runpy.run_path(installer)\n";
    $pythonCmd += "installer_globals['install'](source_dir=source_dir)\n";

    python($pythonCmd);
}

installPlayblastCreatorV204();
